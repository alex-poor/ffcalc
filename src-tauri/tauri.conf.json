{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FFCalc",
  "version": "0.6.0",
  "identifier": "nz.thepho.ffcalc",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": "npm run ui:build"
  },
  "app": {
    "windows": [
      {
        "title": "FFCalc · thePHO Bulk Funding",
        "url": "FFCalc.html",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "appimage"
    ],
    "category": "Productivity",
    "shortDescription": "thePHO Bulk Funding Calculator",
    "longDescription": "Calculate total Te Whatu Ora revenue per funding stream for any demographic roster, and model PHO pass-through pricing.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/alex-poor/ffcalc/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGREU5NTk3RDBDQ0QzMUMKUldRYzA4elFsNVhlVC9EZG9pQ1FsVTFVM0hkcXNvSHNoc1JmVUxCN3ZiUVBKbFc5cXhFV0lVTVQK"
    }
  }
}
